{
  "name": "coffee-journey",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file=.env node_modules/drizzle-kit/bin.cjs migrate",
    "db:seed": "node --env-file=.env node_modules/tsx/dist/cli.mjs db/seed.ts",
    "db:clear-demo": "node --env-file=.env node_modules/tsx/dist/cli.mjs db/clear-demo-data.ts",
    "db:studio": "drizzle-kit studio",
    "auth:generate": "npx auth@latest generate --yes",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "sh -c 'if [ \"$1\" = \"--\" ]; then shift; fi; pnpm db:migrate && pnpm db:seed && playwright test \"$@\"; status=$?; pnpm db:clear-demo; exit $status' --"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1065.0",
    "@aws-sdk/s3-request-presigner": "3.1065.0",
    "better-auth": "1.6.16",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "1.17.0",
    "next": "16.2.9",
    "postgres": "3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "6.0.2",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "jsdom": "29.1.1",
    "@playwright/test": "1.60.0",
    "prettier": "latest",
    "tailwindcss": "4.3.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "packageManager": "pnpm@9.15.4"
}
