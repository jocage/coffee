NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://coffee.example.com

DATABASE_URL=postgres://coffee:coffee@postgres:5432/coffee_journey

BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=https://coffee.example.com
BETTER_AUTH_TRUSTED_ORIGINS=https://coffee.example.com
BETTER_AUTH_RATE_LIMIT_ENABLED=true
BETTER_AUTH_RATE_LIMIT_WINDOW=60
BETTER_AUTH_RATE_LIMIT_MAX=300

APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_WINDOW_SECONDS=60
APP_RATE_LIMIT_MAX=120

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_REGION=auto
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=coffee-journey
CLOUDFLARE_R2_PUBLIC_BASE_URL=

S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PUBLIC_BASE_URL=

LOCAL_UPLOAD_DIR=.local/uploads

SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://analytics.example.com/script.js

SKIP_DB_MIGRATIONS=false
DB_MIGRATION_ATTEMPTS=20
DB_MIGRATION_RETRY_MS=3000
